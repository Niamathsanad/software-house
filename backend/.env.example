# Copy this file to .env and adjust as needed
PORT=4000

# Comma-separated list of origins allowed to call this API (your frontend URL(s))
CORS_ORIGIN=http://127.0.0.1:5500,http://localhost:5500,http://localhost:3000,http://localhost:8080

# Email recipient for contact form submissions
CONTACT_EMAIL=niamatullahsafi594@gmail.com

# Optional SMTP configuration for real email delivery
# For Gmail, use a Google App Password (not your normal password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=niamatullahsafi594@gmail.com
SMTP_PASS=your_gmail_app_password_here
SMTP_FROM=niamatullahsafi594@gmail.com
